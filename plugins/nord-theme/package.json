  "name": "@recall/nord-theme",
  "displayName": "Nord Theme",
  "version": "0.0.1",
  "description": "Adaptation of the popular Nord theme for Recall.",
  "author": "Arctic Ice Studio & Sven Greb <https://www.nordtheme.com/>",
  "homepage": "https://www.nordtheme.com/",
  "recall": {
    "permissions": [
      "ui.theme.static.write"
    ],
    "manifestVersion": "0.0.1",
    "category": "theme",
    "iconUrl": "https://www.nordtheme.com/icons/icon-192x192.png",
    "tags": [
      "theme"
    ],
    "theme": "src/theme.json"
  }
}
