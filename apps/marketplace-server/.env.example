# Cloudflare account credentials used by Drizzle Kit and Wrangler commands.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Worker public configuration. These match wrangler.jsonc vars.
MARKETPLACE_NAME="Recall Plugin Registry"
MARKETPLACE_DESCRIPTION="Cloudflare-hosted registry for Recall plugins."
MARKETPLACE_NAMESPACE="default"
MAX_PLUGIN_ZIP_BYTES=10485760

# Wrangler bindings configured in wrangler.jsonc.
D1_BINDING=DB
D1_DATABASE_NAME=recall-marketplace
D1_DATABASE_ID=replace-with-cloudflare-d1-database-id
R2_BUCKET_BINDING=PLUGIN_BUCKET
R2_BUCKET_NAME=recall-marketplace-plugins
