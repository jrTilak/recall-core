{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "size": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "downloadUrl": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "main": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "theme": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "createdAt": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "size",
    "downloadUrl",
    "manifestVersion",
    "permissions",
    "createdAt"
  ],
  "additionalProperties": false
}
