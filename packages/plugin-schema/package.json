{
	"name": "@jrtilak-recall/plugin-schema",
	"description": "Common schema definitions for Recall plugins.",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"private": false,
	"version": "0.0.1-alpha",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --minify --target bun && tsc -p tsconfig.build.json"
	},
	"devDependencies": {
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5",
		"zod": "^4.4.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
