{
	"name": "@jrtilak-recall/marketplace-interface",
	"description": "Client interface for Recall-compatible marketplace servers",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"private": false,
	"version": "0.0.1-alpha",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --minify --target bun && tsc -p tsconfig.build.json"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
