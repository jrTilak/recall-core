{
	"name": "@jrtilak-recall/marketplace-interface",
	"description": "Client interface for Recall-compatible marketplace servers",
	"homepage": "https://docs.recall.jrtilak.dev/core-packages/marketplace-interface/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jrTilak/recall-core.git",
		"directory": "packages/marketplace-interface"
	},
	"bugs": {
		"url": "https://github.com/jrTilak/recall-core/issues"
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"sideEffects": false,
	"private": false,
	"version": "0.0.2-alpha",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf ./dist && bun build ./src/index.ts ./src/client.ts ./src/server.ts --outdir ./dist --minify --target browser --external zod && tsc -p tsconfig.build.json",
		"test": "bun test"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		}
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
