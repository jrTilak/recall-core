{
	"name": "@jrtilak-recall/plugin-creator",
	"version": "0.0.2-alpha",
	"description": "A plugin creator for Recall",
	"type": "module",
	"bin": {
		"build:plugin": "./dist/build-plugin.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf ./dist && bun build ./src/scripts/build-plugin.ts --outdir ./dist --minify --target bun",
		"prepack": "bun run build"
	},
	"devDependencies": {
		"@types/bun": "latest"
	},
	"dependencies": {
		"@jrtilak-recall/plugin-schema": "^0.0.3-alpha",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
