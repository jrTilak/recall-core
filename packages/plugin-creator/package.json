{
  "name": "@recall/plugin-creator",
  "module": "src/index.ts",
  "description": "A plugin creator for Recall",
  "type": "module",
  "bin": {
    "build:plugin": "./bin/build-plugin.ts"
  },
  "scripts": {
    "build:schema": "bun ./src/scripts/build-plugin-config-schema.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./build-plugin": {
      "types": "./bin/build-plugin.ts",
      "import": "./bin/build-plugin.ts"
    }
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "@recall/logger": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
